{
  "name": "wingman",
  "displayName": "Sqowe Wingman",
  "description": "A VS Code client for the pi coding agent",
  "version": "0.0.2",
  "publisher": "sqowe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sqowe/sqowe-wingman.git"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.82.0",
    "node": ">=20"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "ai",
    "coding agent",
    "pi",
    "sqowe"
  ],
  "activationEvents": [
    "onCommand:sqoweWingman.focusChat",
    "onCommand:sqoweWingman.newSession",
    "onCommand:sqoweWingman.switchSession",
    "onCommand:sqoweWingman.refreshSessions",
    "onCommand:sqoweWingman.setModel",
    "onCommand:sqoweWingman.cycleModel",
    "onCommand:sqoweWingman.compactSession",
    "onCommand:sqoweWingman.forkSession",
    "onCommand:sqoweWingman.cloneSession",
    "onCommand:sqoweWingman.exportHtml",
    "onCommand:sqoweWingman.setThinkingLevel",
    "onCommand:sqoweWingman.cycleThinkingLevel",
    "onCommand:sqoweWingman.showStats",
    "onView:sqoweWingman.chat",
    "onView:sqoweWingman.sessions"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sqowe-wingman",
          "title": "Sqowe Wingman",
          "icon": "media/wingman.svg"
        }
      ]
    },
    "views": {
      "sqowe-wingman": [
        {
          "type": "webview",
          "id": "sqoweWingman.chat",
          "name": "Chat"
        },
        {
          "type": "tree",
          "id": "sqoweWingman.sessions",
          "name": "Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "sqoweWingman.newSession",
        "category": "Sqowe Wingman",
        "title": "New Session",
        "icon": "$(add)"
      },
      {
        "command": "sqoweWingman.focusChat",
        "category": "Sqowe Wingman",
        "title": "Focus Chat"
      },
      {
        "command": "sqoweWingman.switchSession",
        "category": "Sqowe Wingman",
        "title": "Switch Session"
      },
      {
        "command": "sqoweWingman.refreshSessions",
        "category": "Sqowe Wingman",
        "title": "Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "sqoweWingman.setModel",
        "category": "Sqowe Wingman",
        "title": "Set Model",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "sqoweWingman.cycleModel",
        "category": "Sqowe Wingman",
        "title": "Cycle Model"
      },
      {
        "command": "sqoweWingman.compactSession",
        "category": "Sqowe Wingman",
        "title": "Compact Session",
        "icon": "$(fold)"
      },
      {
        "command": "sqoweWingman.forkSession",
        "category": "Sqowe Wingman",
        "title": "Fork Session",
        "icon": "$(repo-forked)"
      },
      {
        "command": "sqoweWingman.cloneSession",
        "category": "Sqowe Wingman",
        "title": "Clone Session",
        "icon": "$(files)"
      },
      {
        "command": "sqoweWingman.exportHtml",
        "category": "Sqowe Wingman",
        "title": "Export Session as HTML",
        "icon": "$(export)"
      },
      {
        "command": "sqoweWingman.setThinkingLevel",
        "category": "Sqowe Wingman",
        "title": "Set Thinking Level",
        "icon": "$(lightbulb)"
      },
      {
        "command": "sqoweWingman.cycleThinkingLevel",
        "category": "Sqowe Wingman",
        "title": "Cycle Thinking Level"
      },
      {
        "command": "sqoweWingman.showStats",
        "category": "Sqowe Wingman",
        "title": "Show Session Stats"
      },
      {
        "command": "sqoweWingman.selectFolder",
        "category": "Sqowe Wingman",
        "title": "Select Workspace Folder",
        "icon": "$(folder-active)"
      },
      {
        "command": "sqoweWingman.trustProject",
        "category": "Sqowe Wingman",
        "title": "Trust Project (.pi/ Resources)"
      }
    ],
    "keybindings": [
      {
        "command": "sqoweWingman.newSession",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n",
        "when": "focusedView == sqoweWingman.chat"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sqoweWingman.newSession",
          "when": "view == sqoweWingman.chat",
          "group": "navigation@1"
        },
        {
          "command": "sqoweWingman.setModel",
          "when": "view == sqoweWingman.chat",
          "group": "navigation@2"
        },
        {
          "command": "sqoweWingman.setThinkingLevel",
          "when": "view == sqoweWingman.chat",
          "group": "navigation@3"
        },
        {
          "command": "sqoweWingman.compactSession",
          "when": "view == sqoweWingman.chat",
          "group": "1_session@1"
        },
        {
          "command": "sqoweWingman.forkSession",
          "when": "view == sqoweWingman.chat",
          "group": "1_session@2"
        },
        {
          "command": "sqoweWingman.cloneSession",
          "when": "view == sqoweWingman.chat",
          "group": "1_session@3"
        },
        {
          "command": "sqoweWingman.exportHtml",
          "when": "view == sqoweWingman.chat",
          "group": "1_session@4"
        },
        {
          "command": "sqoweWingman.selectFolder",
          "when": "view == sqoweWingman.chat && workspaceFolderCount > 1",
          "group": "2_folder@1"
        },
        {
          "command": "sqoweWingman.refreshSessions",
          "when": "view == sqoweWingman.sessions",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "sqoweWingman.switchSession",
          "when": "view == sqoweWingman.sessions && viewItem == session",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Sqowe Wingman",
      "properties": {
        "sqoweWingman.piExecutablePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the `pi` executable (a leading `~` is expanded to your home directory). Leave empty to auto-detect from `PATH` and common install locations (npm global, Homebrew, Volta).",
          "scope": "window"
        }
      }
    }
  },
  "scripts": {
    "install:all": "npm install && npm --prefix webview-ui install",
    "build:host": "node esbuild.mjs",
    "build:webview": "npm --prefix webview-ui run build",
    "build": "npm run build:host && npm run build:webview",
    "watch:host": "node esbuild.mjs --watch",
    "watch:webview": "npm --prefix webview-ui run dev",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:host && npm run test:webview",
    "test:host": "vitest run",
    "test:webview": "npm --prefix webview-ui run test",
    "vscode:prepublish": "npm run build",
    "vsce:package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "18.19.130",
    "@types/vscode": "1.82.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "0.21.5",
    "typescript": "5.5.3",
    "vitest": "1.6.0"
  }
}
